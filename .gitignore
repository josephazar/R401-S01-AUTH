# Ignorer tout sauf tp-labs, exemples-presentation, jwt-demo-template et oauth-jwt-demo-template
/*
!/tp-labs/
!/exemples-presentation/
!/jwt-demo-template/
!/oauth-jwt-demo-template/
!/websockets-demo-template/
!.gitignore
!README.md

# Cacher solutions complètes (référence enseignant uniquement)
jwt-demo/
oauth-jwt-demo/
websockets-demo/

# Node modules
tp-labs/*/node_modules/
jwt-demo-template/backend/node_modules/
jwt-demo-template/frontend/node_modules/
jwt-demo-template/frontend/dist/
oauth-jwt-demo-template/backend/node_modules/
oauth-jwt-demo-template/frontend/node_modules/
oauth-jwt-demo-template/frontend/dist/
websockets-demo-template/backend/node_modules/
websockets-demo-template/frontend/node_modules/
websockets-demo-template/frontend/dist/

# EXCEPTION ÉDUCATIVE : Les fichiers .env sont normalement dans .gitignore
# Ici, ils sont inclus uniquement pour faciliter les TPs et la démo (secrets factices)
# ⚠️ EN PRODUCTION : NE JAMAIS COMMITER DE FICHIERS .env RÉELS !

# Node.js
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Environment variables
.env
.env.local
.env.*.local

# Build output
dist/
build/
*.log

# OS files
.DS_Store
Thumbs.db
# IDE
.vscode/
.idea/
*.swp
*.swo
*~
passport-local-demo
express-passport-jwt-cookies
EasyNodeJSTutorialFromScratch
